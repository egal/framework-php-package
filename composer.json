{
    "name": "egal/framework",
    "description": "The Egal Framework.",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": "^7.4|^8.1",
        "firebase/php-jwt": "^6.0",
        "laravel/framework": "^9.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^8.5.8|^9.3.3",
        "squizlabs/php_codesniffer": "^3.6",
        "spatie/laravel-ignition": "^1.0",
        "slevomat/coding-standard": "^7.0"
    },
    "autoload": {
        "files": [
            "egal/src/Core/functions/dump.php"
        ],
        "psr-4": {
            "Egal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Egal\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Egal\\Core\\ServiceProvider",
                "Egal\\Interface\\ServiceProvider"
            ],
            "aliases": {
                "EgalFilterParser": "Egal\\Core\\Facades\\FilterParser",
                "EgalSelectParser": "Egal\\Core\\Facades\\SelectParser",
                "EgalScopeParser": "Egal\\Core\\Facades\\ScopeParser",
                "EgalOrderParser": "Egal\\Core\\Facades\\OrderParser",
                "EgalGate": "Egal\\Core\\Facades\\Gate",
                "EgalRest": "Egal\\Core\\Facades\\Rest",
                "EgalRoute": "Egal\\Core\\Facades\\Route",
                "EgalInterfaceMetadataManger": "Egal\\Interface\\Facades\\Manager"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
